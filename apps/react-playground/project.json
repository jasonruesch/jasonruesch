{
  "name": "react-playground",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/react-playground/src",
  "projectType": "application",
  "targets": {
    "version": {
      "executor": "@jscutlery/semver:version",
